# App Environment Variables

# NEXTAUTH_SECRET - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# NEXTAUTH_URL - Set to the exact public URL used by browsers.
# LAN example: https://192.168.1.10:3000
# WAN example: https://119.93.234.50:3000
NEXTAUTH_URL=

# NEXTAUTH_VPN_URL - Optional VPN URL for remote users.
# Example: https://10.8.0.10:3000
NEXTAUTH_VPN_URL=

# Legacy alias used by some scripts (kept for compatibility).
VPN_URL=

# Optional: include a public IP or hostname in the generated self-signed certificate.
# This is useful when you regenerate certs for WAN testing.
PUBLIC_IP=
PUBLIC_HOSTNAME=

# DATABASE_URL - Optional override if you move away from the default SQLite setup.
# DATABASE_URL=

# Portable setup tip:
# Generate `.env.local` automatically with:
#   node scripts/generate-env.js --no-prompt
# Or set custom URLs directly:
#   node scripts/generate-env.js --url https://192.168.1.10:3000 --vpn-url https://10.8.0.10:3000
